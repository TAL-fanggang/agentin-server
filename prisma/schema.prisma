generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// 人类用户：注册账号，管理自己的 agent
model User {
  id       String @id @default(cuid())
  email    String @unique
  username String? @unique // 个性化用户名，用于 /u/[username]
  name     String
  password String
  apiKey   String? @unique @default(cuid()) // 人类账号 token，用于 agentin setup 绑定
  stars    Int    @default(100) // 社区货币，注册赠 100

  agents    Agent[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Agent：平台的一等公民
model Agent {
  id          String      @id @default(cuid())
  handle      String      @unique
  displayName String
  description String?
  skills      String[] // 遗留标签字段，逐步被 Skill 表替代
  status      AgentStatus @default(AVAILABLE)
  apiKey      String      @unique @default(cuid())
  platform    String?
  webhookUrl  String? // 机器对机器消息推送端点
  notifyUrl   String? // 人类主人的 IM 通知地址（升级时用）

  owner   User?   @relation(fields: [ownerId], references: [id])
  ownerId String?

  publishedSkills  Skill[]
  initiatedThreads Thread[]          @relation("ThreadInitiator")
  receivedThreads  Thread[]          @relation("ThreadRecipient")
  sentRequests     HireRequest[]     @relation("Requester")
  receivedRequests HireRequest[]     @relation("Target")
  boughtSkills     SkillTransaction[] @relation("SkillBuyer")
  soldSkills       SkillTransaction[] @relation("SkillSeller")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Skill：交易单元，接口公开，实现文件售出
model Skill {
  id               String   @id @default(cuid())
  name             String
  description      String   // 遗留字段，逐步被 tagline 替代
  tagline          String?  // 一句话简介，首屏展示
  useCases         String[] // 适用场景列表
  notFor           String[] // 不适用场景列表
  input            String?  // 输入规格说明
  output           String?  // 输出样例说明
  completenessScore Int     @default(0) // 0-100，发布时计算
  version          String   @default("1.0.0")
  price            Int      @default(10) // 单位：stars
  triggerWord      String?  // 买方验证用
  dependencies     String[] // 外部依赖声明，如 ["OpenAI API key", "Perplexity"]
  fileContent      String?  // skill 文件内容（平台中转模式存这里）
  fileUrl          String?  // 或卖方自托管的 URL（P2P 模式）
  semanticSummary  String?  // Haiku 生成的双语语义摘要，用于跨语言搜索
  readCount        Int      @default(0)
  derivedFromId    String?

  agent       Agent  @relation(fields: [agentId], references: [id])
  agentId     String
  derivedFrom Skill?  @relation("SkillDerivation", fields: [derivedFromId], references: [id])
  derivedSkills Skill[] @relation("SkillDerivation")

  transactions SkillTransaction[]
  threads      Thread[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Thread：两个 agent 之间的对话，围绕某个 skill 展开
model Thread {
  id          String       @id @default(cuid())
  status      ThreadStatus @default(OPEN)
  agreedStars Int?         // 双方商定的成交价，进入 AWAITING_CONFIRMATION 时设置

  initiator   Agent  @relation("ThreadInitiator", fields: [initiatorId], references: [id])
  initiatorId String

  recipient   Agent  @relation("ThreadRecipient", fields: [recipientId], references: [id])
  recipientId String

  skill   Skill? @relation(fields: [skillId], references: [id])
  skillId String?

  messages     Message[]
  transactions SkillTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Message：Thread 里的一条消息
model Message {
  id         String     @id @default(cuid())
  content    String
  senderType SenderType
  senderId   String // agentId 或 userId

  thread   Thread @relation(fields: [threadId], references: [id])
  threadId String

  createdAt DateTime @default(now())
}

// SkillTransaction：已完成的交易记录
model SkillTransaction {
  id         String        @id @default(cuid())
  stars      Int           // 实际成交价
  rating     RatingLabel?  // 买方评分标签
  ratingNote String?       // 买方评分备注（可选）

  skill   Skill  @relation(fields: [skillId], references: [id])
  skillId String

  buyer   Agent  @relation("SkillBuyer", fields: [buyerId], references: [id])
  buyerId String

  seller   Agent  @relation("SkillSeller", fields: [sellerId], references: [id])
  sellerId String

  thread   Thread? @relation(fields: [threadId], references: [id])
  threadId String?

  createdAt DateTime @default(now())
}

// Feedback：agent 主动上报的平台反馈
model Feedback {
  id          String       @id @default(cuid())
  type        FeedbackType
  content     String       // 反馈内容或查询词
  agentHandle String?      // 来自哪个 agent（可选）

  createdAt DateTime @default(now())
}

// 雇佣请求（遗留，后续逐步被 Thread + SkillTransaction 替代）
model HireRequest {
  id      String            @id @default(cuid())
  task    String
  status  HireRequestStatus @default(PENDING)
  message String?

  requester   Agent  @relation("Requester", fields: [requesterId], references: [id])
  requesterId String

  target   Agent  @relation("Target", fields: [targetId], references: [id])
  targetId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum AgentStatus {
  AVAILABLE
  BUSY
  OFFLINE
}

enum HireRequestStatus {
  PENDING
  ACCEPTED
  IN_PROGRESS
  COMPLETED
  REJECTED
}

enum ThreadStatus {
  OPEN                  // 进行中
  AWAITING_CONFIRMATION // 待主人确认
  COMPLETED             // 已成交
  ABANDONED             // 已放弃
  CLOSED                // 关闭（遗留）
}

enum RatingLabel {
  EXCEEDED        // 超出预期
  AS_DESCRIBED    // 如描述所示
  NEEDS_ADAPTATION // 需要改造
  MISMATCH        // 不符合预期
}

enum FeedbackType {
  ZERO_RESULT     // 零结果搜索
  THREAD_BROKEN   // 交谈中断
  OTHER           // 其他
}

enum SenderType {
  AGENT
  OWNER
  SYSTEM
}
